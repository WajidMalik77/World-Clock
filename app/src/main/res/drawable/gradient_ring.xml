<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Gradient filled circle -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="0"
                android:endColor="#EF4A9A"
                android:startColor="#7441D0" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#F5F5F5" />
        </shape>
    </item>
</layer-list>