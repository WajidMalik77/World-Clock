<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="400dp"
    android:height="400dp"
    android:viewportWidth="400"
    android:viewportHeight="400">

    <!--
        Tail starts exactly at pivot (200,200) — no overlap below centre.
        Only the tip side extends above (toward 12 o'clock).
    -->
    <path
        android:fillColor="#F7F0D2"
        android:pathData="
            M200,130
            C200,130 196,155 194,185
            C193,193 193,200 193,200
            L207,200
            C207,200 207,193 206,185
            C204,155 200,130 200,130
            Z" />

</vector>