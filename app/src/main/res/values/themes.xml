<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.WorldClock" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.WorldClock" parent="Base.Theme.WorldClock" />


    <style name="CustomTimePickerTheme" parent="Theme.AppCompat.Light">
        <item name="android:textColorPrimary">#B1B1B1</item>
        <item name="android:textColorSecondary">#B1B1B1</item>
        <item name="android:textSize">@dimen/_24ssp</item>
        <item name="colorAccent">#EF4A9A</item>
    </style>

    <style name="DayChip">
        <item name="android:layout_width">@dimen/_34sdp</item>
        <item name="android:layout_height">@dimen/_34sdp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/grey</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/_14ssp</item>
    </style>

    <style name="Picker">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textSize">@dimen/_20ssp</item>
    </style>


    <style name="DayButtonStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/_28sdp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">@dimen/_6sdp</item>
        <item name="android:background">@drawable/bg_day_unselected</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/_10ssp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="DayOfWeekStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/_9ssp</item>
        <item name="android:textColor">#888888</item>
        <item name="android:paddingBottom">@dimen/_4sdp</item>
    </style>


    <style name="ReminderDayStyle">
        <item name="android:layout_width">@dimen/_26sdp</item>
        <item name="android:layout_height">@dimen/_26sdp</item>
        <item name="android:layout_marginEnd">@dimen/_4sdp</item>
        <item name="android:background">@drawable/bg_unselected_day</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/poppins_regular</item>
        <item name="android:textSize">@dimen/_9ssp</item>
        <item name="android:textColor">@color/black</item>
    </style>

</resources>